# Intuit QuickBooks Online app credentials.
# Get these from https://developer.intuit.com -> your app -> Keys & OAuth.
# IMPORTANT: use the SANDBOX Client ID / Client Secret, not production keys.
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=

# Must exactly match a Redirect URI registered in the Intuit app's
# Keys & OAuth settings (Sandbox section). For local dev this is the
# localhost URL below; when deployed to Vercel, change this to your
# deployment's HTTPS URL (e.g. https://your-app.vercel.app/callback) and
# register that same URL in the Intuit app too.
INTUIT_REDIRECT_URI=http://localhost:8000/callback

# This tool only ever talks to the QuickBooks Sandbox API. This value exists
# as an explicit safety confirmation, not a switch — the app refuses to start
# unless it is exactly "sandbox".
QUICKBOOKS_ENVIRONMENT=sandbox

# Flask session/flash signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Upstash Redis (REST API) — stores the OAuth token so it survives across
# serverless invocations. Create a free database at https://upstash.com,
# then copy its REST URL and token from the database's dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
